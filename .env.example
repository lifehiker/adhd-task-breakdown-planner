# App URL
NEXT_PUBLIC_APP_URL="https://yourdomain.com"

# Database (SQLite - no external service needed)
DATABASE_URL="file:./dev.db"

# NextAuth secret - generate with: openssl rand -base64 32
AUTH_SECRET="your-secret-here"

# Anthropic API key (optional - app works with mock steps without it)
# ANTHROPIC_API_KEY="sk-ant-..."

# Stripe (optional - only needed for subscription upgrades)
# STRIPE_SECRET_KEY="sk_live_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."
# NEXT_PUBLIC_STRIPE_PRICE_MONTHLY="price_..."
# NEXT_PUBLIC_STRIPE_PRICE_YEARLY="price_..."

# Resend email (optional - only needed for reminder emails)
# RESEND_API_KEY="re_..."
# EMAIL_FROM="noreply@yourdomain.com"

# Cron protection (optional)
# CRON_SECRET="your-cron-secret"
